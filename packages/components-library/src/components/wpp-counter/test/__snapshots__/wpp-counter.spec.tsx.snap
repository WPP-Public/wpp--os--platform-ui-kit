exports[`wpp-counter should render component with warning message 1`] = `
<wpp-counter class="wpp-counter" exportparts="label, body, decrease-button, decrease-icon, input, increase-button, increase-icon, message" message-type="warning">
  <mock:shadow-root>
    <div class="counter-wrapper size-m warning" part="body">
      <div class="decrease-wrapper disabled" part="decrease-button">
        <wpp-icon-remove class="icon-minus" part="decrease-icon"></wpp-icon-remove>
      </div>
      <input class="counter-input warning" part="input" type="text" value="1">
      <div class="increase-wrapper" part="increase-button">
        <wpp-icon-plus class="icon-plus" part="increase-icon"></wpp-icon-plus>
      </div>
    </div>
  </mock:shadow-root>
</wpp-counter>
`;
