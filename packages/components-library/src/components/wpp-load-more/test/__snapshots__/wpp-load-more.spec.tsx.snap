  <mock:shadow-root>
    <wpp-button class="load-more-button wpp-button" exportparts="button, spinner-wrapper, spinner, text, inner, icon-start, icon-end, icon-start-wrapper, icon-end-wrapper" part="button">
      <mock:shadow-root>
        <button aria-pressed="false" class="button secondary size-s" data-testid="wppButton" part="button" type="button">
