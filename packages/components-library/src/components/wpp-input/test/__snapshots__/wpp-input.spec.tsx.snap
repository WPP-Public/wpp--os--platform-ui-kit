  <mock:shadow-root>
    <div class="input-with-icons" part="body">
      <div class="icon-start slot-hidden" part="icon-start-wrapper">
        <slot name="icon-start" part="icon-start"></slot>
      </div>
      <wpp-tooltip anchortabindex="-1" class="with-tooltip" disabled="" part="anchor" text="test">
        <input aria-disabled="false" autocomplete="off" class="input-element size-m" data-testid="input" id="text-input" name="text-input" part="input" placeholder="Text" type="text" value="test">
      </wpp-tooltip>
      <div aria-label="Clear input" class="icon-end slot-hidden" part="icon-end-wrapper" role="button" tabindex="-1">
        <slot name="icon-end" part="icon-end"></slot>
      </div>
    </div>
  </mock:shadow-root>
</wpp-input>
`;

exports[`wpp-input should render component with search type 1`] = `
<wpp-input class="with-value wpp-input wpp-size-s" exportparts="label, body, icon-search, input, icon-cross, message, icon-start, icon-start-wrapper, icon-end, icon-end-wrapper" message="Warning message" message-type="warning" name="search-input" placeholder="Text" size="s" type="search" value="test">
  <mock:shadow-root>
    <div class="input-with-icons" part="body">
      <div class="icon-start slot-hidden" part="icon-start-wrapper">
        <slot name="icon-start" part="icon-start"></slot>
      </div>
      <wpp-icon-search class="icon-start slot-hidden" part="icon-search"></wpp-icon-search>
      <wpp-tooltip anchortabindex="-1" class="with-tooltip" disabled="" part="anchor" text="test">
        <input aria-disabled="false" autocomplete="off" class="input-element size-s warning with-icon-end with-icon-start" data-testid="input" id="search-input" name="search-input" part="input" placeholder="Text" type="search" value="test">
      </wpp-tooltip>
      <wpp-icon-cross aria-label="Erase input text" class="icon-end slot-hidden" part="icon-cross" tabindex="0"></wpp-icon-cross>
      <div aria-label="Clear input" class="icon-end slot-hidden" part="icon-end-wrapper" role="button" tabindex="-1">
        <slot name="icon-end" part="icon-end"></slot>
      </div>
    </div>
    <wpp-inline-message message="Warning message" part="message" type="warning"></wpp-inline-message>
  </mock:shadow-root>
</wpp-input>
`;

