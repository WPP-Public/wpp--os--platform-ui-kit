    <wpp-label class="label" optional="" part="body" typography="s-body">
      <input aria-required="false" checked="" class="checkbox-input" part="input" tabindex="0" type="checkbox">
      <div class="square" part="square"></div>
      <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
      <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
    </wpp-label>
  </mock:shadow-root>
</wpp-checkbox>
`;

exports[`wpp-checkbox should render checked disabled checkbox 1`] = `
<wpp-checkbox checked="" class="wpp-checkbox wpp-checkbox-wrapper wpp-checked wpp-disabled" disabled="" exportparts="body, input, square, icon-tick, icon-dash, message">
  <mock:shadow-root>
    <wpp-label class="label" disabled="" optional="" part="body" typography="s-body">
      <input aria-hidden="true" aria-required="false" checked="" class="checkbox-input" disabled="" part="input" tabindex="-1" type="checkbox">
      <div class="square" part="square"></div>
      <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
      <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
    </wpp-label>
  </mock:shadow-root>
</wpp-checkbox>
`;

exports[`wpp-checkbox should render checked disabled checkbox with label 1`] = `
<wpp-checkbox checked="" class="wpp-checkbox wpp-checkbox-wrapper wpp-checked wpp-disabled" disabled="" exportparts="body, input, square, icon-tick, icon-dash, message">
  <mock:shadow-root>
    <wpp-label class="label with-text wpp-label" disabled="" exportparts="wrapper, content, icon" part="body">
      <input aria-hidden="true" aria-required="false" checked="" class="checkbox-input" disabled="" part="input" tabindex="-1" type="checkbox">
      <div class="square" part="square"></div>
      <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
      <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
      <label class="internal-label-wrapper" part="wrapper">
        <wpp-internal-label class="disabled s-body wpp-internal-label" disabled="" exportparts="info-wrapper, text, optional-text, tooltip, icon, icon-wrapper" part="content">
          <mock:shadow-root>
            <div class="info-wrapper" part="info-wrapper" role="presentation">
              <wpp-typography class="text" part="text" type="s-body">
                Label
              </wpp-typography>
              <wpp-typography class="optional" part="optional-text" type="s-body">
                (Optional)
              </wpp-typography>
            </div>
            <div aria-label="Show info" class="icon slot-hidden" part="icon-wrapper" role="button" tabindex="0">
              <slot name="icon" part="icon"></slot>
            </div>
          </mock:shadow-root>
        </wpp-internal-label>
      </label>
    </wpp-label>
  </mock:shadow-root>
</wpp-checkbox>
`;

