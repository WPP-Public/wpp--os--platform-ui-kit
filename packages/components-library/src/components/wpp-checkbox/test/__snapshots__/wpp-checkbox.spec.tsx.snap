// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`wpp-checkbox should render checkbox 1`] = `
<wpp-checkbox class="wpp-checkbox wpp-checkbox-wrapper" exportparts="body, input, square, icon-tick, icon-dash, message">
  <mock:shadow-root>
    <wpp-label class="label" optional="" part="body" typography="s-body">
      <input aria-required="false" class="checkbox-input" part="input" tabindex="0" type="checkbox">
      <div class="square" part="square"></div>
      <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
      <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
    </wpp-label>
  </mock:shadow-root>
</wpp-checkbox>
`;

exports[`wpp-checkbox should render checked checkbox 1`] = `
<wpp-checkbox checked="" class="wpp-checkbox wpp-checkbox-wrapper wpp-checked" exportparts="body, input, square, icon-tick, icon-dash, message">
