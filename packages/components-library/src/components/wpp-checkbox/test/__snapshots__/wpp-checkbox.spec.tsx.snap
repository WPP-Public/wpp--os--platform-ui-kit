exports[`wpp-checkbox should render indeterminate disabled checkbox with label, icon and tooltip description 1`] = `
<wpp-checkbox class="wpp-checkbox wpp-checkbox-wrapper wpp-disabled wpp-indeterminate" disabled="" exportparts="body, input, square, icon-tick, icon-dash, message" indeterminate="" name="checkbox">
  <mock:shadow-root>
    <wpp-label class="label with-text wpp-label" disabled="" exportparts="wrapper, content, icon" part="body">
      <input aria-hidden="true" aria-required="false" checked="" class="checkbox-input" disabled="" id="checkbox" name="checkbox" part="input" tabindex="-1" type="checkbox">
      <div class="square" part="square"></div>
      <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
      <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
      <label aria-label="checkbox" class="internal-label-wrapper" htmlfor="checkbox" part="wrapper">
        <wpp-internal-label class="disabled s-body wpp-internal-label" disabled="" exportparts="info-wrapper, text, optional-text, tooltip, icon, icon-wrapper" part="content">
          <mock:shadow-root>
            <div class="info-wrapper with-icon" part="info-wrapper" role="presentation">
              <wpp-typography class="text" part="text" type="s-body">
                Test label
              </wpp-typography>
              <wpp-typography class="optional" part="optional-text" type="s-body">
                (Optick)
              </wpp-typography>
            </div>
            <wpp-tooltip class="tooltip" part="tooltip" text="Your email will be used to send you a confirmation number">
              <div aria-label="Show info" class="icon" part="icon-wrapper" role="button" tabindex="0">
                <slot name="icon" part="icon"></slot>
              </div>
            </wpp-tooltip>
          </mock:shadow-root>
          <wpp-icon-mail-v3-1-1 part="icon" slot="icon"></wpp-icon-mail-v3-1-1>
        </wpp-internal-label>
      </label>
    </wpp-label>
  </mock:shadow-root>
</wpp-checkbox>
`;
