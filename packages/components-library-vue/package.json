{
  "name": "@platform-ui-kit/components-library-vue",
  "description": "Vue bindings for components-library",
  "version": "3.1.1",

  "scripts": {
    "clean": "rimraf lib node_modules",

    "build": "tsc --project tsconfig.lib.json",
    "build-watch": "tsc-watch --project tsconfig.lib.json --preserveWatchOutput --onSuccess \"npm run yalc-push\"",

    "prebuild": "npm run build --workspace @platform-ui-kit/components-library",

    "yalc-push": "dotenv-extended --path=../../.env validEnv RUN_YALC && yalc push"
  },

  "files": [
    "lib"
  ],

  "main": "lib/index.js",

  "peerDependencies": {
    "@platform-ui-kit/components-library": "3.1.1",

    "vue": "^3.2.45"
  },

  "dependencies": {
    "tslib": "2.4.0"
  },

  "devDependencies": {
    "typescript": "*",
    "tsc-watch": "^6.0.4"
  },

  "publishConfig": {
    "registry": "https://github.com/WPP-Public/wpp--os--platform-ui-kit"
  },
  "repository": "https://github.com/WPP-Public/wpp--os--platform-ui-kit"
}
