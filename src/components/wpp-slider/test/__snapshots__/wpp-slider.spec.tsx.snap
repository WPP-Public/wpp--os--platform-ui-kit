    <div class="size-m with-value without-label" part="control-wrapper">
      <div class="range-value-wrapper" part="value-wrapper">
        <wpp-typography part="value" type="s-midi">
          1
        </wpp-typography>
        <wpp-divider class="divider" part="value-divider"></wpp-divider>
        <wpp-typography part="value" type="s-midi">
          3
