            <wpp-tooltip class="tooltip" part="tooltip" text="Your email will be used to send you a confirmation number">
              <div aria-label="Show info" class="icon" part="icon-wrapper" role="button" tabindex="0">
                <slot name="icon" part="icon"></slot>
              </div>
            </wpp-tooltip>
          </mock:shadow-root>
          <wpp-icon-mail-v3-2-0 part="icon" slot="icon"></wpp-icon-mail-v3-2-0>
        </wpp-internal-label>
      </label>
    </wpp-label>
    <div class="slider-container">
      <div class="slider-column">
        <div class="range-slider-wrapper" part="slider">
          <div class="slider-clickable-wrapper"></div>
          <input class="min-range-idle slider" max="5" min="1" part="input-slider-min" step="2" type="range" value="1" style="--active-range-from-progress-bar: 0%; --active-range-to-progress-bar: 50%;">
          <input class="max-range-idle slider" max="5" min="1" part="input-slider-max" step="2" type="range" value="3">
        </div>
      </div>
    </div>
  </mock:shadow-root>
</wpp-slider>
`;

