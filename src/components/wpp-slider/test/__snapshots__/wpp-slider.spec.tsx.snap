exports[`wpp-slider should render slider with generated marks 1`] = `
<wpp-slider class="wpp-slider" exportparts="label, input-number, input-wrapper, input-min, divider, input-max, control-wrapper, editable-input-wrapper, value, value-wrapper, value-divider, mark, mark-circle, mark-inner, slider, input-slider-min, input-slider-max, marks-list" marks="" max="7" value="5">
  <mock:shadow-root>
    <div class="slider-container">
      <div class="slider-column">
        <div class="single-slider-wrapper" part="slider">
          <div class="slider-clickable-wrapper"></div>
          <input class="max-range-idle slider" max="7" min="1" part="input-slider-max" step="1" type="range" value="5" style="--active-single-progress-bar: 66.66666666666666%;">
        </div>
        <div class="marks-list size-m" part="marks-list">
          <div class="active first mark-item" part="mark" style="--mark-left-dynamic: calc(0% - var(--slider-mark-size) / 2);">
            <div class="circle" part="mark-circle">
              <div class="mark" part="mark-inner"></div>
            </div>
            <div class="label-container">
              <wpp-typography class="label size-m" id="mark-label-1" part="label" type="xs-body">
                1
              </wpp-typography>
            </div>
          </div>
          <div class="active mark-item" part="mark" style="--mark-left-dynamic: calc(16.666666666666664% - var(--slider-mark-size) / 2 + 4px);">
            <div class="circle" part="mark-circle">
              <div class="mark" part="mark-inner"></div>
            </div>
            <div class="label-container">
              <wpp-typography class="label size-m" id="mark-label-2" part="label" type="xs-body">
                2
              </wpp-typography>
            </div>
          </div>
          <div class="active mark-item" part="mark" style="--mark-left-dynamic: calc(33.33333333333333% - var(--slider-mark-size) / 2 + 2px);">
            <div class="circle" part="mark-circle">
              <div class="mark" part="mark-inner"></div>
            </div>
            <div class="label-container">
              <wpp-typography class="label size-m" id="mark-label-3" part="label" type="xs-body">
                3
              </wpp-typography>
            </div>
          </div>
          <div class="active mark-item" part="mark" style="--mark-left-dynamic: calc(50% - var(--slider-mark-size) / 2 + 0px);">
            <div class="circle" part="mark-circle">
              <div class="mark" part="mark-inner"></div>
            </div>
            <div class="label-container">
              <wpp-typography class="label size-m" id="mark-label-4" part="label" type="xs-body">
                4
              </wpp-typography>
            </div>
          </div>
          <div class="active mark-item" part="mark" style="--mark-left-dynamic: calc(66.66666666666666% - var(--slider-mark-size) / 2 + -2px);">
            <div class="circle" part="mark-circle">
              <div class="mark" part="mark-inner"></div>
            </div>
            <div class="label-container">
              <wpp-typography class="label size-m" id="mark-label-5" part="label" type="xs-body">
                5
              </wpp-typography>
            </div>
          </div>
          <div class="mark-item" part="mark" style="--mark-left-dynamic: calc(83.33333333333333% - var(--slider-mark-size) / 2 + -4px);">
            <div class="circle" part="mark-circle">
              <div class="mark" part="mark-inner"></div>
            </div>
            <div class="label-container">
              <wpp-typography class="label size-m" id="mark-label-6" part="label" type="xs-body">
                6
              </wpp-typography>
            </div>
          </div>
          <div class="last mark-item" part="mark" style="--mark-left-dynamic: calc(100% - var(--slider-mark-size) / 2);">
            <div class="circle" part="mark-circle">
              <div class="mark" part="mark-inner"></div>
            </div>
            <div class="label-container">
              <wpp-typography class="label size-m" id="mark-label-7" part="label" type="xs-body">
