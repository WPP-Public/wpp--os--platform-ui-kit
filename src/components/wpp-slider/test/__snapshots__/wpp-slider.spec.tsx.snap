exports[`wpp-slider should render range slider with displayed value 1`] = `
<wpp-slider class="wpp-slider" exportparts="label, input-number, input-wrapper, input-min, divider, input-max, control-wrapper, editable-input-wrapper, value, value-wrapper, value-divider, mark, mark-circle, mark-inner, slider, input-slider-min, input-slider-max, marks-list" with-value="">
