          <input class="min-range-idle slider" max="5" min="1" part="input-slider-min" step="2" type="range" value="1" style="--active-range-from-progress-bar: 0%; --active-range-to-progress-bar: 50%;">
          <input class="max-range-idle slider" max="5" min="1" part="input-slider-max" step="2" type="range" value="3">
        </div>
      </div>
    </div>
  </mock:shadow-root>
</wpp-slider>
`;

exports[`wpp-slider should render range slider with label, icon and tooltip description 1`] = `
<wpp-slider class="wpp-slider" exportparts="label, input-number, input-wrapper, input-min, divider, input-max, control-wrapper, editable-input-wrapper, value, value-wrapper, value-divider, mark, mark-circle, mark-inner, slider, input-slider-min, input-slider-max, marks-list">
