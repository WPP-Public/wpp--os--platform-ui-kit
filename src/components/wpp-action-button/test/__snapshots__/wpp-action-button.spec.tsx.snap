// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`wpp-action-button Testing snapshots Testing default button 1`] = `
<wpp-action-button class="wpp-action-button" exportparts="button, spinner-wrapper, spinner, body, icon-start-wrapper, icon-start, icon-end-wrapper, icon-end, inner, overlay">
  <mock:shadow-root>
    <button aria-pressed="false" class="primary" data-testid="wppActionButton" part="button" type="button">
      <div class="content" part="body">
        <div class="icon-start slot-hidden" part="icon-start-wrapper">
          <slot name="icon-start" part="icon-start"></slot>
        </div>
        <slot part="inner"></slot>
        <div class="icon-end slot-hidden" part="icon-end-wrapper">
          <slot name="icon-end" part="icon-end"></slot>
        </div>
      </div>
    </button>
    <div class="overlay" part="overlay"></div>
  </mock:shadow-root>
  Button
</wpp-action-button>
`;

