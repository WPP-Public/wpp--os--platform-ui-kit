exports[`wpp-action-button Testing snapshots Testing loading secondary submit button 1`] = `
<wpp-action-button class="wpp-action-button wpp-loading" exportparts="button, spinner-wrapper, spinner, body, icon-start-wrapper, icon-start, icon-end-wrapper, icon-end, inner, overlay" loading="" type="submit" variant="secondary">
  <mock:shadow-root>
    <button aria-pressed="false" class="loading secondary" data-testid="wppActionButton" disabled="" part="button" type="submit">
      <div class="loader" part="spinner-wrapper">
        <wpp-spinner color="var(--wpp-grey-color-800)" part="spinner"></wpp-spinner>
      </div>
      <div class="content hide" part="body">
        <div class="icon-start slot-hidden" part="icon-start-wrapper">
          <slot name="icon-start" part="icon-start"></slot>
        </div>
        <slot part="inner"></slot>
        <div class="icon-end slot-hidden" part="icon-end-wrapper">
          <slot name="icon-end" part="icon-end"></slot>
        </div>
      </div>
    </button>
    <div class="overlay" part="overlay"></div>
  </mock:shadow-root>
  Submit Button
</wpp-action-button>
`;

