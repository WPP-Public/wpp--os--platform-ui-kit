      <wpp-label class="label with-text" htmlfor="fax" part="body" typography="s-body">
        <input aria-required="true" class="checkbox-input" id="fax" name="fax" part="input" required="" tabindex="0" type="checkbox">
        <div class="square" part="square"></div>
        <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
        <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
      </wpp-label>
    </mock:shadow-root>
  </wpp-checkbox>
</wpp-checkbox-group>
`;
