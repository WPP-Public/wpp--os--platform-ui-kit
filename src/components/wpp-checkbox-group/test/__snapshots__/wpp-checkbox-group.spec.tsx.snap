// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`wpp-checkbox-group should render checkbox-group with 4 items 1`] = `
<wpp-checkbox-group class="wpp-checkbox-group" direction="column" exportparts="inner">
  <mock:shadow-root>
    <div aria-labelledby="label-id" class="group-container" role="group">
      <div class="content direction-column">
        <slot part="inner"></slot>
      </div>
    </div>
  </mock:shadow-root>
  <wpp-checkbox class="wpp-checkbox wpp-checkbox-wrapper" exportparts="body, input, square, icon-tick, icon-dash, message" name="email" required="">
    <mock:shadow-root>
      <wpp-label class="label with-text" htmlfor="email" part="body" typography="s-body">
        <input aria-required="true" class="checkbox-input" id="email" name="email" part="input" required="" tabindex="0" type="checkbox">
        <div class="square" part="square"></div>
        <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
        <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
      </wpp-label>
    </mock:shadow-root>
  </wpp-checkbox>
  <wpp-checkbox class="wpp-checkbox wpp-checkbox-wrapper" exportparts="body, input, square, icon-tick, icon-dash, message" name="mail" required="">
    <mock:shadow-root>
      <wpp-label class="label with-text" htmlfor="mail" part="body" typography="s-body">
        <input aria-required="true" class="checkbox-input" id="mail" name="mail" part="input" required="" tabindex="0" type="checkbox">
        <div class="square" part="square"></div>
        <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
        <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
      </wpp-label>
    </mock:shadow-root>
  </wpp-checkbox>
  <wpp-checkbox class="wpp-checkbox wpp-checkbox-wrapper" exportparts="body, input, square, icon-tick, icon-dash, message" name="phone" required="">
    <mock:shadow-root>
      <wpp-label class="label with-text" htmlfor="phone" part="body" typography="s-body">
        <input aria-required="true" class="checkbox-input" id="phone" name="phone" part="input" required="" tabindex="0" type="checkbox">
        <div class="square" part="square"></div>
        <wpp-icon-tick part="icon-tick"></wpp-icon-tick>
        <wpp-icon-dash part="icon-dash"></wpp-icon-dash>
      </wpp-label>
    </mock:shadow-root>
  </wpp-checkbox>
  <wpp-checkbox class="wpp-checkbox wpp-checkbox-wrapper" exportparts="body, input, square, icon-tick, icon-dash, message" name="fax" required="">
