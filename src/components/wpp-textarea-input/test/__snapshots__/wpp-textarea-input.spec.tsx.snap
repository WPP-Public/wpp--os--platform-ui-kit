        </wpp-typography>
      </div>
    </div>
  </mock:shadow-root>
</wpp-textarea-input>
`;

exports[`wpp-textarea-input renders component with error message and label, icon and tooltip description 1`] = `
<wpp-textarea-input class="wpp-textarea-input wpp-textarea-wrapper" exportparts="label, textarea, message-wrapper, message, limit-wrapper, limit-label, limit-text" message-type="warning">
  <mock:shadow-root>
    <wpp-label class="label wpp-label" exportparts="wrapper, content, icon" part="label">
      <label class="internal-label-wrapper" part="wrapper">
        <wpp-internal-label class="s-strong wpp-internal-label" exportparts="info-wrapper, text, optional-text, tooltip, icon, icon-wrapper" part="content">
          <mock:shadow-root>
            <div class="info-wrapper with-icon" part="info-wrapper" role="presentation">
              <wpp-typography class="text" part="text" type="s-strong">
                Test label
              </wpp-typography>
              <wpp-typography class="optional" part="optional-text" type="s-body">
                (Optick)
              </wpp-typography>
            </div>
            <wpp-tooltip class="tooltip" part="tooltip" text="Your email will be used to send you a confirmation number">
              <div aria-label="Show info" class="icon" part="icon-wrapper" role="button" tabindex="0">
                <slot name="icon" part="icon"></slot>
              </div>
            </wpp-tooltip>
          </mock:shadow-root>
          <wpp-icon-mail-v3-3-0 part="icon" slot="icon"></wpp-icon-mail-v3-3-0>
        </wpp-internal-label>
      </label>
    </wpp-label><textarea class="warning" part="textarea"></textarea>
    <div class="messages-wrapper" part="message-wrapper">
      <wpp-inline-message class="wpp-inline-message wpp-size-s wpp-warning" exportparts="wrapper, message-icon, message, message-block" part="message">
        <mock:shadow-root>
          <div class="inline-message-wrapper size-s warning-message" part="wrapper">
            <div class="message-block tooltip-maxlength-auto" part="message-block">
              <wpp-icon-warning class="left-icon" part="message-icon" role="presentation"></wpp-icon-warning>
              <span class="message" part="message">
                warning message
              </span>
            </div>
          </div>
        </mock:shadow-root>
      </wpp-inline-message>
    </div>
  </mock:shadow-root>
</wpp-textarea-input>
`;
