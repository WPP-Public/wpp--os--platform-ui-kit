// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`wpp-textarea-input renders component 1`] = `
<wpp-textarea-input class="wpp-textarea-input wpp-textarea-wrapper" exportparts="label, textarea, message-wrapper, message, limit-wrapper, limit-label, limit-text">
  <mock:shadow-root><textarea part="textarea"></textarea>
  </mock:shadow-root>
</wpp-textarea-input>
`;

exports[`wpp-textarea-input renders component with characters-limit and warning text messages 1`] = `
<wpp-textarea-input characters-limit="40" class="wpp-textarea-input wpp-textarea-wrapper" error-threshold="25" exportparts="label, textarea, message-wrapper, message, limit-wrapper, limit-label, limit-text" message="Warning message" message-type="warning" warning-threshold="30">
  <mock:shadow-root><textarea class="warning" part="textarea"></textarea>
    <div class="messages-wrapper" part="message-wrapper">
      <wpp-inline-message class="wpp-inline-message wpp-size-s wpp-warning" exportparts="wrapper, message-icon, message, message-block" part="message">
        <mock:shadow-root>
          <div class="inline-message-wrapper size-s warning-message" part="wrapper">
            <div class="message-block tooltip-maxlength-auto" part="message-block">
              <wpp-icon-warning class="left-icon" part="message-icon" role="presentation"></wpp-icon-warning>
              <span class="message" part="message">
                Warning message
              </span>
            </div>
          </div>
        </mock:shadow-root>
      </wpp-inline-message>
      <div class="characters-limit" data-testid="char-entered-label" part="limit-wrapper">
        <wpp-typography part="limit-label" tag="span" type="xs-body">
          Characters:
        </wpp-typography>
        <wpp-typography class="entered-characters" part="limit-text" tag="span" type="xs-strong">
          0/40
        </wpp-typography>
      </div>
    </div>
  </mock:shadow-root>
</wpp-textarea-input>
`;

exports[`wpp-textarea-input renders component with characters-limit message 1`] = `
<wpp-textarea-input characters-limit="40" class="wpp-textarea-input wpp-textarea-wrapper" error-threshold="25" exportparts="label, textarea, message-wrapper, message, limit-wrapper, limit-label, limit-text" warning-threshold="30">
  <mock:shadow-root><textarea part="textarea"></textarea>
    <div class="messages-wrapper without-text-message" part="message-wrapper">
