// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`wpp-autocomplete should render empty 1`] = `
<wpp-autocomplete class="wpp-autocomplete" exportparts="input, dropdown, options, selected-values" style="--wpp-list-item-width: 100%;">
  <mock:shadow-root>
    <div class="autocomplete-wrapper">
      <div class="size-m trigger">
        <div class="values">
          <wpp-icon-search></wpp-icon-search>
          <input autocomplete="off" class="autocomplete-input" part="input" tabindex="0" type="text" value="">
        </div>
        <div class="trigger-actions"></div>
      </div>
    </div>
    <div class="dropdown" part="dropdown" style="--custom-dropdown-width: undefinedpx;">
      <div class="dropdown-list" part="options">
        <wpp-list-item class="nothing-found-wrapper">
          <wpp-typography class="nothing-found" slot="label" type="s-body">
            Nothing found
          </wpp-typography>
        </wpp-list-item>
      </div>
    </div>
  </mock:shadow-root>
</wpp-autocomplete>
`;

exports[`wpp-autocomplete should render empty with label, icon and tooltip description 1`] = `
<wpp-autocomplete class="wpp-autocomplete" exportparts="input, dropdown, options, selected-values" style="--wpp-list-item-width: 100%;">
  <mock:shadow-root>
    <div class="autocomplete-wrapper">
      <wpp-label class="label wpp-label" exportparts="wrapper, content, icon">
        <label class="internal-label-wrapper" part="wrapper">
          <wpp-internal-label class="s-strong wpp-internal-label" exportparts="info-wrapper, text, optional-text, tooltip, icon, icon-wrapper" part="content">
            <mock:shadow-root>
              <div class="info-wrapper with-icon" part="info-wrapper" role="presentation">
                <wpp-typography class="text" part="text" type="s-strong">
                  Test label
                </wpp-typography>
                <wpp-typography class="optional" part="optional-text" type="s-body">
                  (Optick)
                </wpp-typography>
              </div>
              <wpp-tooltip class="tooltip" part="tooltip" text="Your email will be used to send you a confirmation number">
                <div aria-label="Show info" class="icon" part="icon-wrapper" role="button" tabindex="0">
                  <slot name="icon" part="icon"></slot>
                </div>
              </wpp-tooltip>
            </mock:shadow-root>
            <wpp-icon-mail-v3-3-0 part="icon" slot="icon"></wpp-icon-mail-v3-3-0>
          </wpp-internal-label>
        </label>
      </wpp-label>
      <div class="size-m trigger">
        <div class="values">
          <wpp-icon-search></wpp-icon-search>
          <input autocomplete="off" class="autocomplete-input" part="input" tabindex="0" type="text" value="">
        </div>
        <div class="trigger-actions"></div>
      </div>
    </div>
    <div class="dropdown" part="dropdown" style="--custom-dropdown-width: undefinedpx;">
      <div class="dropdown-list" part="options">
        <wpp-list-item class="nothing-found-wrapper">
          <wpp-typography class="nothing-found" slot="label" type="s-body">
            Nothing found
          </wpp-typography>
        </wpp-list-item>
      </div>
    </div>
  </mock:shadow-root>
</wpp-autocomplete>
`;

exports[`wpp-autocomplete should render opened in loading state 1`] = `
<wpp-autocomplete class="wpp-autocomplete" exportparts="input, dropdown, options, selected-values" loading="" style="--wpp-list-item-width: 100%;">
  <mock:shadow-root>
    <div class="autocomplete-wrapper">
      <div class="size-m trigger warning">
        <div class="values">
          <wpp-icon-search></wpp-icon-search>
          <wpp-typography class="input-placeholder" data-testid="wpp-autocomplete-input-placeholder" type="s-body">
            Item 1
          </wpp-typography>
          <input autocomplete="off" class="autocomplete-input hidden" id="test" name="test" part="input" placeholder="Select Items" tabindex="0" type="text" value="">
        </div>
        <div class="trigger-actions"></div>
      </div>
      <wpp-inline-message class="inline-message" message="Test message" type="warning"></wpp-inline-message>
    </div>
    <div class="dropdown" part="dropdown" style="--custom-dropdown-width: undefinedpx;">
      <div class="dropdown-list" part="options">
        <div class="loading-wrapper">
          <wpp-spinner slot="left"></wpp-spinner>
          <wpp-typography slot="label" type="s-body">
            Loading...
          </wpp-typography>
        </div>
      </div>
    </div>
  </mock:shadow-root>
  <wpp-list-item class="wpp-list-item wpp-mounted" exportparts="item, info-wrapper, checkbox, body-wrapper, left, label, caption, right, left-wrapper, label-wrapper, caption-wrapper, right-wrapper" highlight="" label="Item 1" role="presentation" tabindex="0" value="1">
    <mock:shadow-root>
      <ul class="ul-wrapper" part="ul-wrapper">
        <li class="item" part="item">
          <div class="info-wrapper" part="info-wrapper">
            <div class="left slot-hidden" part="left-wrapper">
              <slot name="left" part="left"></slot>
            </div>
            <div class="body-wrapper" part="body-wrapper" style="width: auto;">
              <div class="label" part="label-wrapper">
                <slot name="label" part="label"></slot>
              </div>
              <div class="caption slot-hidden" part="caption-wrapper">
                <slot name="caption" part="caption"></slot>
              </div>
            </div>
          </div>
          <div class="right slot-hidden" part="right-wrapper">
            <slot name="right" part="right"></slot>
          </div>
        </li>
      </ul>
    </mock:shadow-root>
    <p slot="label">
      Item 1
    </p>
  </wpp-list-item>
  <wpp-list-item class="wpp-list-item wpp-mounted" exportparts="item, info-wrapper, checkbox, body-wrapper, left, label, caption, right, left-wrapper, label-wrapper, caption-wrapper, right-wrapper" highlight="" label="Item 2" role="presentation" tabindex="0" value="2">
