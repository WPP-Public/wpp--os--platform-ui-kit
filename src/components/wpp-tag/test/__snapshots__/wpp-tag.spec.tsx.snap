exports[`wpp-tag snapshots should render tag with warning variant and truncated label 1`] = `
<wpp-tag class="wpp-tag" exportparts="label, tooltip, tooltip-text, icon-start, overlay" label="This is a very long label that exceeds the maximum allowed characters.">
  <mock:shadow-root>
    <div class="icon-start slot-hidden" part="icon-start-wrapper">
      <slot name="icon-start" part="icon-start"></slot>
    </div>
    <wpp-typography part="label" tag="span" type="xs-midi">
      <wpp-tooltip part="tooltip" text="This is a very long label that exceeds the maximum allowed characters.">
        <span part="tooltip-text">
          This is a very long label tha…
        </span>
      </wpp-tooltip>
    </wpp-typography>
    <div class="overlay" part="overlay"></div>
  </mock:shadow-root>
</wpp-tag>
`;
