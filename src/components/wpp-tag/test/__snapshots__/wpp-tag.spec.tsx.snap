// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`wpp-tag snapshots should render disabled tag 1`] = `
<wpp-tag class="wpp-disabled wpp-tag" disabled="" exportparts="label, tooltip, tooltip-text, icon-start, overlay">
  <mock:shadow-root>
    <div class="icon-start slot-hidden" part="icon-start-wrapper">
      <slot name="icon-start" part="icon-start"></slot>
    </div>
    <wpp-typography part="label" tag="span" type="xs-midi"></wpp-typography>
    <div class="overlay" part="overlay"></div>
  </mock:shadow-root>
</wpp-tag>
`;

exports[`wpp-tag snapshots should render tag with categorical color index 1`] = `
<wpp-tag categorical-color-index="4" class="wpp-tag" exportparts="label, tooltip, tooltip-text, icon-start, overlay" style="--tag-bg-color: var(--wpp-dataviz-color-cat-light-4);">
  <mock:shadow-root>
    <div class="icon-start slot-hidden" part="icon-start-wrapper">
      <slot name="icon-start" part="icon-start"></slot>
    </div>
    <wpp-typography part="label" tag="span" type="xs-midi"></wpp-typography>
    <div class="overlay" part="overlay"></div>
  </mock:shadow-root>
</wpp-tag>
`;

