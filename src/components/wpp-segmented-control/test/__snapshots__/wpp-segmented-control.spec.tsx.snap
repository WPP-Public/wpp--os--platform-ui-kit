exports[`wpp-segmented-control should render item with text and counter 1`] = `
<wpp-segmented-control-item class="wpp-segmented-control-item" counter="2" exportparts="item" tabindex="0" value="item-1">
  <mock:shadow-root>
    <div aria-selected="false" class="segmented-control-item size-m text" id="item-1" part="item" role="option">
      <div class="content-wrapper" part="ws-wrapper">
        <slot part="ws-inner"></slot>
      </div>
      <div class="counter">
        (2)
      </div>
    </div>
  </mock:shadow-root>
  Text
</wpp-segmented-control-item>
`;
