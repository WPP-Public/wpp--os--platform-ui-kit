// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`wpp-segmented-control should render bar with icons and size s 1`] = `
<wpp-segmented-control class="wpp-segmented-control" exportparts="wrapper, inner, label" size="s" style="--wpp-bar-width: auto;">
  <mock:shadow-root>
    <div aria-multiselectable="false" class="size-s wpp-bar-wrapper" part="wrapper" role="listbox">
      <slot part="inner"></slot>
    </div>
  </mock:shadow-root>
  <wpp-segmented-control-item active="" class="wpp-segmented-control-item" exportparts="item" tabindex="-1" value="item-1" variant="icon">
    <mock:shadow-root>
      <div aria-selected="true" class="active icon segmented-control-item size-m" id="item-1" part="item" role="option">
        <div class="content-wrapper" part="ws-wrapper">
          <slot part="ws-inner"></slot>
        </div>
      </div>
    </mock:shadow-root>
    <wpp-icon-grid-dots></wpp-icon-grid-dots>
  </wpp-segmented-control-item>
  <wpp-segmented-control-item class="wpp-segmented-control-item" exportparts="item" tabindex="0" value="item-2" variant="icon">
    <mock:shadow-root>
      <div aria-selected="false" class="icon segmented-control-item size-m" id="item-2" part="item" role="option">
        <div class="content-wrapper" part="ws-wrapper">
          <slot part="ws-inner"></slot>
        </div>
      </div>
    </mock:shadow-root>
    <wpp-icon-list></wpp-icon-list>
  </wpp-segmented-control-item>
  <wpp-segmented-control-item class="wpp-segmented-control-item" exportparts="item" tabindex="0" value="item-3" variant="icon">
    <mock:shadow-root>
      <div aria-selected="false" class="icon segmented-control-item size-m" id="item-3" part="item" role="option">
        <div class="content-wrapper" part="ws-wrapper">
          <slot part="ws-inner"></slot>
        </div>
      </div>
    </mock:shadow-root>
    <wpp-icon-addd-document></wpp-icon-addd-document>
  </wpp-segmented-control-item>
</wpp-segmented-control>
`;

