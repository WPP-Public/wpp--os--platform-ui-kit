{
  "name": "@platform-ui-kit/angular-example",
  "version": "3.1.1",
  "scripts": {
    "start": "ng serve",
    "eslint": "eslint src/**/*.{ts,tsx} --no-error-on-unmatched-pattern",
    "eslint:fix": "npm run eslint -- --fix",
    "stylelint": "stylelint src/**/*.scss --allow-empty-input",
    "stylelint:fix": "npm run stylelint -- --fix",
    "clean": "rimraf .angular node_modules",
    "prestart": "npm run build --workspace @platform-ui-kit/components-library-angular"
  },
  "dependencies": {
    "@angular/core": "14.3.0",
    "@angular/common": "14.3.0",
    "@angular/forms": "14.3.0",
    "@angular/platform-browser": "^14.3.0",
    "@angular/platform-browser-dynamic": "14.3.0",
    "@angular/router": "14.3.0",
    "@platform-ui-kit/components-library": "*",
    "@platform-ui-kit/components-library-angular": "*",
    "ag-grid-community": "28.1.0",
    "ag-grid-angular": "28.1.0",
    "swiper": "11.0.6",
    "tslib": "2.4.0",
    "zone.js": "0.11.5"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "14.1.0",
    "@angular-devkit/build-angular": "14.2.13",
    "@angular/cli": "14.2.13",
    "@angular/compiler": "14.3.0",
    "@angular/compiler-cli": "14.3.0",
    "typescript": "4.6.4"
  },
  "private": true
}
