  "dependencies": {
    "@platform-ui-kit/components-library": "*"
  },
  "private": true,
  "devDependencies": {
    "css-loader": "6.7.1",
    "html-loader": "4.2.0",
    "html-webpack-plugin": "5.5.0",
    "webpack": "5.74.0",
    "webpack-cli": "4.10.0"
  }
}
