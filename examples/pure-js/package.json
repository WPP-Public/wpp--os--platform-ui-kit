{
  "name": "@platform-ui-kit/pure-js-example",
  "version": "3.1.1",
  "scripts": {
    "build": "rm -rf dist && webpack",
    "eslint": "eslint src/**/*.{ts,tsx} --no-error-on-unmatched-pattern",
