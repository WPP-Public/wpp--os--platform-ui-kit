{
  "name": "@wppopen/components-library",
  "description": "WPP Platform Open Components Library",
  "version": "3.2.0",
  "files": [
    "components",
    "dist",
    "loader"
  ],
  "collection:main": "dist/collection/index.js",
  "collection": "dist/collection/collection-manifest.json",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "unpkg": "dist/test-storybook-web-components/test-storybook-web-components.esm.js",
  "scripts": {
    "start:storybook": "storybook dev -p 6007 --no-open",
    "build:storybook": "storybook build",
    "clean": "rimraf components dist loader storybook-static node_modules",
    "build": "node ./build.js",
    "build-watch": "npm run build -- --watch",
    "test": "export TZ=UTC; stencil test --spec --coverage --maxWorkers=1",
    "test:clear": "jest --clearCache",
    "test-watch": "npm run test -- --watch",
    "test:snapshot": "export TZ=UTC; jest --updateSnapshot",
    "eslint": "eslint src/**/*.{ts,tsx} --no-error-on-unmatched-pattern",
    "eslint:fix": "npm run eslint -- --fix",
    "stylelint": "stylelint src/**/*.scss --allow-empty-input",
    "stylelint:fix": "npm run stylelint -- --fix",
    "prestart:storybook": "npm run build",
    "prebuild:storybook": "npm run build",
    "prebuild": "npx rimraf dist",
    "pretest": "npx rimraf dist"
  },
  "dependencies": {
    "@maskito/core": "3.10.3",
    "@maskito/kit": "3.10.3",
    "@maskito/phone": "3.10.3",
    "@stencil/core": "https://public-assets.os.wpp.com/stencil/stencil-core-4.2.2.tgz",
    "@types/quill": "1.3.7",
    "air-datepicker": "3.6.0",
    "extend": "^3.0.2",
    "highlight-words": "1.2.2",
    "libphonenumber-js": "1.10.57",
    "lodash": "4.17.21",
    "marked": "^15.0.7",
    "quill": "1.3.7",
    "quilljs-markdown": "^1.2.0",
    "tippy.js": "6.3.7",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "1.1.0",
    "@stencil/react-output-target": "0.5.1",
    "@stencil/sass": "3.0.4",
    "@storybook/addon-a11y": "9.0.17",
    "@storybook/addon-docs": "9.0.17",
    "@storybook/mdx2-csf": "1.1.0",
    "@storybook/web-components-vite": "9.0.17",
    "eslint-plugin-storybook": "9.0.17",
    "jest": "^27.0.3",
    "jest-cli": "^27.4.5",
    "lit": "^3.3.1",
    "stencil-inline-svg": "1.1.0",
    "storybook": "9.0.17"
  },
  "publishConfig": {
    "registry": "https://wppopen.jfrog.io/artifactory/api/npm/wpp-open-libs-npm-local/"
  },
  "repository": "https://gitlab.com/2sixty/chaos/osmium/public/tools/platform-ui-kit"
}
