{
  "name": "@wppopen/components-library",
  "description": "WPP Platform Open Components Library",
  "version": "4.1.0",
  "files": [
    "components",
    "dist",
    "loader"
  ],
  "collection:main": "dist/collection/index.js",
  "collection": "dist/collection/collection-manifest.json",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "unpkg": "dist/test-storybook-web-components/test-storybook-web-components.esm.js",
  "scripts": {
    "start:storybook": "storybook dev -p 6007 --no-open",
    "build:storybook": "storybook build",
    "clean": "rimraf components dist loader storybook-static node_modules",
    "build": "node ./build.js",
    "build-watch": "npm run build -- --watch",
    "test": "export TZ=UTC; stencil test --spec --coverage --maxWorkers=1",
    "test:clear": "jest --clearCache",
    "test-watch": "npm run test -- --watch",
    "test:snapshot": "export TZ=UTC; jest --updateSnapshot",
    "test:richtext": "export TZ=UTC; stencil test --spec --maxWorkers=1 -- --testPathPattern=wpp-richtext",
    "eslint": "eslint src/**/*.{ts,tsx} --no-error-on-unmatched-pattern",
    "eslint:fix": "npm run eslint -- --fix",
    "stylelint": "stylelint src/**/*.scss --allow-empty-input",
    "stylelint:fix": "npm run stylelint -- --fix",
    "prestart:storybook": "npm run build",
    "prebuild:storybook": "npm run build",
    "prebuild": "npx rimraf dist",
    "pretest": "npx rimraf dist",
    "comparison:serve": "npm run build && npx http-server ./dist -o /components/wpp-richtext/test/comparison-page.html -p 3333"
  },
  "dependencies": {
    "@maskito/core": "5.0.0",
    "@maskito/kit": "5.0.0",
    "@maskito/phone": "5.0.0",
    "@stencil/core": "https://public-assets.os.wpp.com/stencil/stencil-core-4.2.2.tgz",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-character-count": "^3.20.4",
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-task-item": "^3.22.1",
    "@tiptap/extension-task-list": "^3.22.1",
    "@tiptap/extension-text-align": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/extension-typography": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/markdown": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@types/quill": "1.3.7",
    "air-datepicker": "3.6.0",
    "dompurify": "^3.3.3",
    "extend": "^3.0.2",
    "highlight-words": "1.2.2",
    "jsdom": "^28.1.0",
    "libphonenumber-js": "1.10.57",
    "lodash": "4.18.1",
    "marked": "^15.0.7",
    "quill": "1.3.7",
    "quilljs-markdown": "^1.2.0",
    "tippy.js": "6.3.7",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@jest/core": "^27.5.1",
    "@stencil/angular-output-target": "1.1.0",
    "@stencil/react-output-target": "0.5.1",
    "@stencil/sass": "3.0.4",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/addon-docs": "9.1.20",
    "@storybook/mdx2-csf": "1.1.0",
    "@storybook/web-components-vite": "9.1.20",
    "eslint-plugin-storybook": "9.1.20",
    "jest": "^27.0.3",
    "jest-cli": "^27.4.5",
    "jest-config": "^27.5.1",
    "jest-environment-node": "^27.4.4",
    "jest-runner": "^27.5.1",
    "lit": "^3.3.1",
    "stencil-inline-svg": "1.1.0",
    "storybook": "9.1.20"
  },
  "publishConfig": {
    "registry": "https://github.com/WPP-Public/wpp--os--platform-ui-kit"
  },
  "repository": "https://github.com/WPP-Public/wpp--os--platform-ui-kit"
}
